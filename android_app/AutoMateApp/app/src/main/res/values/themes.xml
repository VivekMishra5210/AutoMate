<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme (supports Light + Dark via DayNight) -->
    <style name="Theme.AutoMate" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <!-- No Action Bar Theme (same as base, kept for clarity) -->
    <style name="Theme.AutoMate.NoActionBar" parent="Theme.AutoMate" />

    <!-- Custom Button Style -->
    <style name="Widget.AutoMate.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.AutoMate.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="strokeColor">@color/primary</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.AutoMate.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">@dimen/corner_radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">@dimen/spacing_md</item>
    </style>

    <!-- TextInput Style -->
    <style name="Widget.AutoMate.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_md</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_hint</item>
    </style>

    <!-- Base Text Appearance -->
    <style name="TextAppearance.AutoMate" parent="TextAppearance.Material3.BodyLarge" />

    <!-- Stat Number Text -->
    <style name="TextAppearance.AutoMate.StatNumber">
        <item name="android:textSize">@dimen/stat_number_size</item>
        <item name="android:textColor">@color/primary_light</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Stat Label Text -->
    <style name="TextAppearance.AutoMate.StatLabel">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
